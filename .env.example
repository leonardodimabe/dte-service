# Copia a .env y ajusta. Prefijo DTE_.

# Base de datos PostgreSQL
DTE_DATABASE_URL=postgresql+psycopg://dte:dte@localhost:5432/dte_service

# Pool de conexiones por worker (dimensionar según workers x concurrencia).
DTE_DB_POOL_SIZE=10
DTE_DB_MAX_OVERFLOW=20

# Llaves Fernet (coma-separadas; la primera cifra, todas descifran → rotación).
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DTE_FERNET_KEYS=

# Carpeta con los XSD oficiales del SII (del motor dte_chile)
DTE_SCHEMAS_DIR=schemas

# Clave de máquina de BOOTSTRAP para /admin (>=16 chars; el servicio NO arranca
# con el ejemplo). Genérala: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Recomendado: úsala solo para crear claves por consumidor en POST /machine-keys
# (hasheadas en BD, con rol e identidad propios y revocables) y migrar Odoo a esas.
DTE_ADMIN_API_KEY=

# Portal (JWT). OBLIGATORIO (>=32 chars): el servicio NO arranca sin él.
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
DTE_JWT_SECRET=
DTE_JWT_EXPIRE_MINUTES=120

# Cookie de sesión del portal (HttpOnly). Secure exige HTTPS:
# true en producción (TLS), false solo en dev sobre http.
DTE_COOKIE_SECURE=true

# Superadmin sembrado al arranque (idempotente). Si se deja vacío, no se siembra.
DTE_SUPERADMIN_EMAIL=
DTE_SUPERADMIN_PASSWORD=

# Orígenes permitidos para la SPA (coma-separados). Vacío = sin CORS (dev usa el proxy de Vite).
DTE_CORS_ORIGINS=

# Timeout de las llamadas al SII (segundos)
DTE_REQUEST_TIMEOUT_S=60

# Rate limiting (estado por proceso: con N workers el límite efectivo es ~N x).
# Login del portal: intentos por IP por minuto. Tenant: fallos de auth por IP / 5 min.
DTE_LOGIN_ATTEMPTS_PER_MINUTE=10
DTE_TENANT_AUTH_FAILURES_PER_5MIN=30

DTE_LOG_LEVEL=INFO
