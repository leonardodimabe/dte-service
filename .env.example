# Copia a .env y ajusta. Prefijo DTE_.

# Base de datos PostgreSQL
DTE_DATABASE_URL=postgresql+psycopg://dte:dte@localhost:5432/dte_service

# Llaves Fernet (coma-separadas; la primera cifra, todas descifran → rotación).
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DTE_FERNET_KEYS=

# Carpeta con los XSD oficiales del SII (del motor dte_chile)
DTE_SCHEMAS_DIR=schemas

# API key global para los endpoints /admin (máquina, p.ej. Odoo)
DTE_ADMIN_API_KEY=change-me

# Portal (JWT). Secret de >=32 bytes en producción.
DTE_JWT_SECRET=change-me-jwt-usa-uno-largo-y-aleatorio
DTE_JWT_EXPIRE_MINUTES=480

# Superadmin sembrado al arranque (idempotente). Si se deja vacío, no se siembra.
DTE_SUPERADMIN_EMAIL=
DTE_SUPERADMIN_PASSWORD=

# Orígenes permitidos para la SPA (coma-separados). Vacío = sin CORS (dev usa el proxy de Vite).
DTE_CORS_ORIGINS=

# Timeout de las llamadas al SII (segundos)
DTE_REQUEST_TIMEOUT_S=60

DTE_LOG_LEVEL=INFO
